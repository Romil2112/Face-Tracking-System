# Face Tracking API — environment variables.
# Copy to .env and fill in values. All are optional; defaults = current behavior.

# Max upload size in bytes. Default: 10485760 (10 MiB).
MAX_UPLOAD_BYTES=10485760

# Per-IP rate limit on POST /detect. Default: 30/minute.
# Format: "<count>/<period>" — period: second|minute|hour|day.
RATE_LIMIT_PER_MINUTE=30/minute

# Maximum simultaneous /detect requests. Overflow returns HTTP 503. Default: 10.
MAX_CONCURRENT_DETECTIONS=10

# Enable blink-based liveness detection. Default: false.
# REST /detect always reports checked=false (single-frame input).
# Blink check (checked=true) only runs in webcam mode (main.py).
LIVENESS_CHECK_ENABLED=false

# Anthropic API key. If unset, triage is silently disabled.
ANTHROPIC_API_KEY=

# Confidence threshold below which Claude triage fires (?triage=true only). Default: 0.6.
TRIAGE_CONFIDENCE_THRESHOLD=0.6
